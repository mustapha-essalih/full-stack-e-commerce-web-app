# Application
APP_NAME=PharosCommerce                    # Application name
APP_ENV=local                              # Environment: local, staging, production
APP_KEY=                                   # 32-char base64 key (generate via `php artisan key:generate`)
APP_DEBUG=true                             # Enable detailed error messages
APP_URL=http://localhost                    # App URL for route generation

# Locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance
APP_MAINTENANCE_DRIVER=file                # Storage driver for maintenance mode

# Bcrypt
BCRYPT_ROUNDS=12                           # Cost factor for password hashing

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql                        # Database driver
DB_HOST=pgsql                              # Database host (Docker service name)
DB_PORT=5432                               # Database port
DB_DATABASE=pharos                         # Database name
DB_USERNAME=pharos                         # Database username
DB_PASSWORD=pharos                         # Database password

# Session (Redis)
SESSION_DRIVER=redis                       # Session driver
SESSION_LIFETIME=120                       # Session lifetime in minutes
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local                      # Default filesystem disk

# Queue (Redis)
QUEUE_CONNECTION=redis                     # Queue driver

# Cache (Redis)
CACHE_STORE=redis                          # Cache store

# Redis
REDIS_CLIENT=phpredis                      # Redis client (phpredis or predis)
REDIS_HOST=redis                           # Redis host (Docker service name)
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Mailpit in dev, SMTP in production)
MAIL_MAILER=smtp                          # Use 'smtp' with Mailpit in dev
MAIL_HOST=127.0.0.1                       # Mailpit host (or SMTP host)
MAIL_PORT=1025                            # Mailpit SMTP port (use 2525 for alternative)
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@pharoscommerce.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (S3, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"

# Telescope
TELESCOPE_ENABLED=true                     # Enable Laravel Telescope in local

# Stripe
STRIPE_KEY=                                # Stripe publishable key
STRIPE_SECRET=                             # Stripe secret key
STRIPE_WEBHOOK_SECRET=                     # Stripe webhook signing secret
